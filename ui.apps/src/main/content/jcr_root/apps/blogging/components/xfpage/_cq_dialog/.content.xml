<?xml version="1.0" encoding="UTF-8"?>
<jcr:root xmlns:jcr="http://www.jcp.org/jcr/1.0" xmlns:nt="http://www.jcp.org/jcr/nt/1.0" xmlns:granite="http://www.adobe.com/jcr/granite/1.0" xmlns:cq="http://www.day.com/jcr/cq/1.0" xmlns:sling="http://sling.apache.org/jcr/sling/1.0"
    jcr:primaryType="nt:unstructured"
    jcr:title="Experience Fragment"
    sling:resourceType="cq/gui/components/authoring/dialog"
    extraClientlibs="[cq.common.wcm,core.wcm.page.properties,cq.wcm.msm.properties,cq.siteadmin.admin.properties,cq.experience-fragments.properties.tabs, cq.experience-fragments.target.properties, granite.contexthub.configuration]"
    mode="edit">
    <content
        granite:class="cq-dialog-content-page"
        jcr:primaryType="nt:unstructured"
        sling:resourceType="granite/ui/components/coral/foundation/container">
        <items jcr:primaryType="nt:unstructured">
            <tabs
                granite:class="cq-siteadmin-admin-properties-tabs"
                jcr:primaryType="nt:unstructured"
                sling:resourceType="granite/ui/components/coral/foundation/tabs"
                size="L">
                <items jcr:primaryType="nt:unstructured">
                    <basic
                        jcr:primaryType="nt:unstructured"
                        jcr:title="Basic"
                        sling:resourceType="granite/ui/components/coral/foundation/fixedcolumns">
                        <layout
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="granite/ui/components/foundation/layouts/fixedcolumns"
                            margin="{Boolean}false"/>
                        <items jcr:primaryType="nt:unstructured">
                            <column
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/container">
                                <items jcr:primaryType="nt:unstructured">
                                    <title
                                        jcr:primaryType="nt:unstructured"
                                        jcr:title="Title and Tags"
                                        sling:resourceType="granite/ui/components/coral/foundation/form/fieldset">
                                        <items jcr:primaryType="nt:unstructured">
                                            <title
                                                cq:showOnCreate="{Boolean}true"
                                                jcr:primaryType="nt:unstructured"
                                                sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                                fieldLabel="Title"
                                                name="./jcr:title"
                                                required="{Boolean}true"/>
                                            <pagename
                                                cq:hideOnEdit="{Boolean}true"
                                                cq:showOnCreate="{Boolean}true"
                                                jcr:primaryType="nt:unstructured"
                                                sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                                fieldLabel="Name"
                                                name="pageName"
                                                validation="foundation.jcr.name"/>
                                            <description
                                                cq:showOnCreate="{Boolean}true"
                                                jcr:primaryType="nt:unstructured"
                                                sling:resourceType="granite/ui/components/coral/foundation/form/textarea"
                                                allowBulkEdit="{Boolean}true"
                                                fieldLabel="Description"
                                                name="./jcr:description"/>
                                            <tags
                                                cq:showOnCreate="{Boolean}true"
                                                jcr:primaryType="nt:unstructured"
                                                sling:resourceType="cq/gui/components/coral/common/form/tagfield"
                                                allowBulkEdit="{Boolean}true"
                                                allowCreate="{Boolean}true"
                                                fieldLabel="Tags"
                                                multiple="true"
                                                name="./cq:tags"/>
                                            <hideVariation
                                                jcr:primaryType="nt:unstructured"
                                                sling:resourceType="granite/ui/components/coral/foundation/form/checkbox"
                                                fieldDescription="The variation cannot be used on web pages."
                                                name="./cq:xfShowInEditor"
                                                text="Hide in Editor"
                                                value="false"/>
                                            <charset
                                                jcr:primaryType="nt:unstructured"
                                                sling:resourceType="granite/ui/components/coral/foundation/form/hidden"
                                                allowBulkEdit="{Boolean}true"
                                                ignoreData="{Boolean}true"
                                                name="_charset_"
                                                value="utf-8"/>
                                            <AuthorName
                                                cq:showOnCreate="{Boolean}true"
                                                jcr:primaryType="nt:unstructured"
                                                sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                                fieldLabel="AuthorName"
                                                name="./jcr:AuthorName"
                                                required="{Boolean}true"/>
                                        </items>
                                    </title>
                                </items>
                            </column>
                        </items>
                    </basic>
                    <advanced
                        cq:showOnCreate="{Boolean}false"
                        jcr:primaryType="nt:unstructured"
                        jcr:title="Advanced"
                        sling:resourceType="granite/ui/components/coral/foundation/fixedcolumns">
                        <items jcr:primaryType="nt:unstructured">
                            <column
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/container">
                                <items jcr:primaryType="nt:unstructured">
                                    <section1
                                        jcr:primaryType="nt:unstructured"
                                        jcr:title="Settings"
                                        sling:resourceType="granite/ui/components/coral/foundation/form/fieldset">
                                        <items jcr:primaryType="nt:unstructured">
                                            <language
                                                cq:showOnCreate="{Boolean}false"
                                                granite:class="xf-translations-dropdown"
                                                jcr:primaryType="nt:unstructured"
                                                sling:resourceType="granite/ui/components/coral/foundation/form/select"
                                                class="language"
                                                cq-msm-lockable="jcr:language"
                                                emptyText="Select"
                                                fieldLabel="Language"
                                                name="./jcr:language"
                                                renderReadOnly="{Boolean}true"
                                                translateOptions="{Boolean}true">
                                                <datasource
                                                    jcr:primaryType="nt:unstructured"
                                                    sling:resourceType="cq/gui/components/common/datasources/languages"
                                                    addNone="{Boolean}true"/>
                                            </language>
                                        </items>
                                    </section1>
                                </items>
                            </column>
                        </items>
                    </advanced>
                    <layout-information
                        cq:showOnCreate="{Boolean}false"
                        jcr:primaryType="nt:unstructured"
                        jcr:title="Smart Layout Settings"
                        sling:resourceType="granite/ui/components/coral/foundation/fixedcolumns">
                        <items jcr:primaryType="nt:unstructured">
                            <column
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/container">
                                <items jcr:primaryType="nt:unstructured">
                                    <section1
                                        jcr:primaryType="nt:unstructured"
                                        jcr:title="Grid information"
                                        sling:resourceType="granite/ui/components/coral/foundation/form/fieldset">
                                        <items jcr:primaryType="nt:unstructured">
                                            <fields
                                                jcr:primaryType="nt:unstructured"
                                                sling:resourceType="granite/ui/components/coral/foundation/fixedcolumns">
                                                <items jcr:primaryType="nt:unstructured">
                                                    <col1
                                                        jcr:primaryType="nt:unstructured"
                                                        sling:resourceType="granite/ui/components/coral/foundation/container">
                                                        <items jcr:primaryType="nt:unstructured">
                                                            <min-cols
                                                                granite:class="min-cols"
                                                                jcr:primaryType="nt:unstructured"
                                                                sling:resourceType="granite/ui/components/coral/foundation/form/numberfield"
                                                                fieldLabel="Minimum columns"
                                                                max="12"
                                                                min="1"
                                                                name="./cq:metadata/min-cols"
                                                                step="1"
                                                                value="1"/>
                                                        </items>
                                                    </col1>
                                                    <col2
                                                        jcr:primaryType="nt:unstructured"
                                                        sling:resourceType="granite/ui/components/coral/foundation/container">
                                                        <items jcr:primaryType="nt:unstructured">
                                                            <max-cols
                                                                granite:class="max-cols"
                                                                jcr:primaryType="nt:unstructured"
                                                                sling:resourceType="granite/ui/components/coral/foundation/form/numberfield"
                                                                fieldLabel="Maximum columns"
                                                                max="12"
                                                                min="1"
                                                                name="./cq:metadata/max-cols"
                                                                step="1"
                                                                value="1"/>
                                                        </items>
                                                    </col2>
                                                </items>
                                            </fields>
                                        </items>
                                    </section1>
                                </items>
                            </column>
                        </items>
                    </layout-information>
                    <thumbnail
                        cq:showOnCreate="{Boolean}false"
                        jcr:primaryType="nt:unstructured"
                        jcr:title="Image Rendition"
                        sling:resourceType="granite/ui/components/coral/foundation/fixedcolumns">
                        <items jcr:primaryType="nt:unstructured">
                            <column
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/container">
                                <items jcr:primaryType="nt:unstructured">
                                    <thumbanil
                                        jcr:primaryType="nt:unstructured"
                                        jcr:title="Thumbnail"
                                        sling:resourceType="granite/ui/components/coral/foundation/form/fieldset">
                                        <items jcr:primaryType="nt:unstructured">
                                            <thumbnail
                                                jcr:primaryType="nt:unstructured"
                                                sling:resourceType="cq/gui/components/common/wcm/pagethumbnail"
                                                page="${empty param.item ? requestPathInfo.suffix : param.item}"
                                                quiet="{Boolean}true">
                                                <upload
                                                    granite:class="cq-wcm-fileupload"
                                                    jcr:primaryType="nt:unstructured"
                                                    sling:resourceType="granite/ui/components/coral/foundation/form/hidden">
                                                    <granite:data
                                                        jcr:primaryType="nt:unstructured"
                                                        cq-msm-lockable="/image"/>
                                                </upload>
                                                <preview
                                                    jcr:primaryType="nt:unstructured"
                                                    sling:resourceType="cq/gui/components/siteadmin/admin/pagepreview"/>
                                            </thumbnail>
                                        </items>
                                    </thumbanil>
                                    <imagerenderer
                                        jcr:primaryType="nt:unstructured"
                                        jcr:title="Image renderer"
                                        sling:resourceType="granite/ui/components/coral/foundation/form/fieldset">
                                        <items jcr:primaryType="nt:unstructured">
                                            <imagerenderer
                                                jcr:primaryType="nt:unstructured"
                                                sling:resourceType="cq/experience-fragments/components/imagerenderer"
                                                path="${empty param.item ? requestPathInfo.suffix : param.item}"/>
                                        </items>
                                    </imagerenderer>
                                </items>
                            </column>
                        </items>
                    </thumbnail>
                    <cloudservices
                        cq:hideOnEdit="false"
                        cq:showOnCreate="{Boolean}false"
                        jcr:primaryType="nt:unstructured"
                        jcr:title="Cloud Services"
                        sling:resourceType="granite/ui/components/coral/foundation/fixedcolumns">
                        <items jcr:primaryType="nt:unstructured">
                            <column
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/container">
                                <items jcr:primaryType="nt:unstructured">
                                    <configuration
                                        jcr:primaryType="nt:unstructured"
                                        jcr:title="Configuration"
                                        sling:resourceType="granite/ui/components/coral/foundation/form/fieldset">
                                        <items jcr:primaryType="nt:unstructured">
                                            <cqConf
                                                jcr:primaryType="nt:unstructured"
                                                sling:resourceType="cq/experience-fragments/components/xfconfigpathbrowser"
                                                emptyText="Select Configuration Path"
                                                fieldLabel="Cloud Configuration">
                                                <granite:data
                                                    jcr:primaryType="nt:unstructured"
                                                    cq-msm-lockable="cq:conf"/>
                                            </cqConf>
                                        </items>
                                    </configuration>
                                    <cloudservices
                                        jcr:primaryType="nt:unstructured"
                                        sling:resourceType="granite/ui/components/coral/foundation/include"
                                        path="wcm/foundation/components/basicpage/v1/basicpage/cq:dialog/content/items/tabs/items/cloudservices"/>
                                    <columnexport
                                        granite:class="cq-adobe-target-export-properties"
                                        jcr:primaryType="nt:unstructured"
                                        sling:resourceType="granite/ui/components/coral/foundation/container">
                                        <items jcr:primaryType="nt:unstructured">
                                            <radiobuttons
                                                granite:class="cq-adobe-target-export-format"
                                                jcr:primaryType="nt:unstructured"
                                                sling:resourceType="granite/ui/components/coral/foundation/form/radiogroup"
                                                fieldLabel="Adobe Target Export Format"
                                                name="./cq:adobeTargetExportFormat"
                                                vertical="{Boolean}true">
                                                <items jcr:primaryType="nt:unstructured">
                                                    <html
                                                        jcr:primaryType="nt:unstructured"
                                                        sling:resourceType="granite/ui/components/coral/foundation/form/radio"
                                                        checked="{Boolean}true"
                                                        text="HTML"
                                                        value="html"/>
                                                    <json
                                                        jcr:primaryType="nt:unstructured"
                                                        sling:resourceType="granite/ui/components/coral/foundation/form/radio"
                                                        text="JSON"
                                                        value="json"/>
                                                    <both
                                                        jcr:primaryType="nt:unstructured"
                                                        sling:resourceType="granite/ui/components/coral/foundation/form/radio"
                                                        text="HTML &amp; JSON"
                                                        value="html,json"/>
                                                </items>
                                                <granite:data
                                                    jcr:primaryType="nt:unstructured"
                                                    cq-msm-lockable="./cq:adobeTargetExportFormat"/>
                                            </radiobuttons>
                                            <dropdown
                                                granite:class="cq-adobe-target-export-workspace"
                                                jcr:primaryType="nt:unstructured"
                                                sling:resourceType="granite/ui/components/coral/foundation/form/select"
                                                fieldDescription="This setting will only be applied when Target is integrated via IMS authentication using the REST api."
                                                fieldLabel="Adobe Target Workspace"
                                                name="./cq:adobeTargetExportWorkspace">
                                                <granite:data
                                                    jcr:primaryType="nt:unstructured"
                                                    cq-msm-lockable="./cq:adobeTargetExportWorkspace"/>
                                                <datasource
                                                    jcr:primaryType="nt:unstructured"
                                                    sling:resourceType="cq/experience-fragments/components/admin/targetworkspacesdatasource"
                                                    path="${empty param.item ? requestPathInfo.suffix : param.item }"/>
                                            </dropdown>
                                            <externalizer
                                                granite:id="externalizername"
                                                jcr:primaryType="nt:unstructured"
                                                sling:resourceType="granite/ui/components/coral/foundation/form/select"
                                                emptyText="Select domain"
                                                fieldLabel="Externalizer Domain"
                                                multiple="false"
                                                name="./cq:externalizerName">
                                                <datasource
                                                    jcr:primaryType="nt:unstructured"
                                                    sling:resourceType="cq/experience-fragments/components/experiencefragment/datasources/externalizer"/>
                                            </externalizer>
                                        </items>
                                    </columnexport>
                                    <targetFormatDelete
                                        jcr:primaryType="nt:unstructured"
                                        sling:resourceType="granite/ui/components/coral/foundation/form/hidden"
                                        name="./cq:adobeTargetExportFormat@Delete"/>
                                    <targetWorkspaceDelete
                                        jcr:primaryType="nt:unstructured"
                                        sling:resourceType="granite/ui/components/coral/foundation/form/hidden"
                                        name="./cq:adobeTargetExportWorkspace@Delete"/>
                                    <targetExternalizerDelete
                                        jcr:primaryType="nt:unstructured"
                                        sling:resourceType="granite/ui/components/coral/foundation/form/hidden"
                                        name="./cq:externalizerName@Delete"/>
                                </items>
                            </column>
                        </items>
                    </cloudservices>
                    <personalization
                        jcr:primaryType="nt:unstructured"
                        jcr:title="Personalization"
                        sling:resourceType="granite/ui/components/coral/foundation/container">
                        <items jcr:primaryType="nt:unstructured">
                            <personalization
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/include"
                                path="/mnt/overlay/wcm/foundation/components/basicpage/v1/basicpage/tabs/personalization"/>
                        </items>
                    </personalization>
                    <permissions
                        jcr:primaryType="nt:unstructured"
                        sling:resourceType="granite/ui/components/coral/foundation/include"
                        path="/mnt/overlay/wcm/core/content/sites/properties/tabs/permissions"/>
                    <blueprint
                        cq:hideOnEdit="{Boolean}false"
                        cq:showOnCreate="{Boolean}false"
                        granite:class="cq-siteadmin-admin-properties-blueprint"
                        jcr:primaryType="nt:unstructured"
                        jcr:title="Blueprint"
                        sling:resourceType="granite/ui/components/coral/foundation/fixedcolumns">
                        <granite:rendercondition
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="wcm/msm/components/touch-ui/renderconditions/isblueprint"
                            path="${empty param.item ? requestPathInfo.suffix : param.item}"/>
                        <items jcr:primaryType="nt:unstructured">
                            <column
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/container">
                                <items jcr:primaryType="nt:unstructured">
                                    <writeblueprintconfig
                                        jcr:primaryType="nt:unstructured"
                                        sling:resourceType="granite/ui/components/coral/foundation/form/hidden"
                                        name="msm:writeBlueprintConfig"
                                        value="true"/>
                                    <livecopies
                                        granite:class="xf-lc-path"
                                        jcr:primaryType="nt:unstructured"
                                        jcr:title="Current Live Copies"
                                        sling:resourceType="granite/ui/components/coral/foundation/form/fieldset">
                                        <items jcr:primaryType="nt:unstructured">
                                            <title
                                                jcr:primaryType="nt:unstructured"
                                                sling:resourceType="wcm/msm/components/coral/touch-ui/propertiesdialog/blueprint/livecopies"
                                                path="${empty param.item ? requestPathInfo.suffix : param.item }"/>
                                        </items>
                                    </livecopies>
                                    <rolloutconfiguration
                                        jcr:primaryType="nt:unstructured"
                                        jcr:title="Rollout Configs"
                                        sling:resourceType="granite/ui/components/coral/foundation/form/fieldset">
                                        <items jcr:primaryType="nt:unstructured">
                                            <rolloutconfigs
                                                jcr:primaryType="nt:unstructured"
                                                sling:resourceType="wcm/msm/components/touch-ui/propertiesdialog/blueprint/rolloutconfigs"
                                                emptyText="Choose Rollout Config"
                                                name="msm:blueprintRolloutConfigs"
                                                path="${empty param.item ? requestPathInfo.suffix : param.item }">
                                                <datasource
                                                    jcr:primaryType="nt:unstructured"
                                                    sling:resourceType="wcm/msm/components/datasources/rolloutconfig"/>
                                            </rolloutconfigs>
                                        </items>
                                    </rolloutconfiguration>
                                </items>
                            </column>
                        </items>
                    </blueprint>
                    <livecopy
                        cq:showOnCreate="{Boolean}false"
                        granite:class="cq-siteadmin-admin-properties-livecopy"
                        jcr:primaryType="nt:unstructured"
                        jcr:title="Live Copy"
                        sling:resourceType="granite/ui/components/coral/foundation/fixedcolumns">
                        <granite:rendercondition
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="wcm/msm/components/touch-ui/renderconditions/islivecopy"
                            path="${empty param.item ? requestPathInfo.suffix : param.item}"/>
                        <items jcr:primaryType="nt:unstructured">
                            <column
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/container">
                                <items jcr:primaryType="nt:unstructured">
                                    <writelivecopyconfig
                                        jcr:primaryType="nt:unstructured"
                                        sling:resourceType="granite/ui/components/coral/foundation/form/hidden"
                                        name="msm:writeLiveCopyConfig"
                                        value="true"/>
                                    <suspendedNote
                                        jcr:primaryType="nt:unstructured"
                                        sling:resourceType="granite/ui/components/coral/foundation/well">
                                        <items jcr:primaryType="nt:unstructured">
                                            <text
                                                jcr:primaryType="nt:unstructured"
                                                sling:resourceType="granite/ui/components/coral/foundation/text"
                                                text="The Live Copy has been suspended. No action will be performed on a roll out."/>
                                        </items>
                                        <granite:rendercondition
                                            jcr:primaryType="nt:unstructured"
                                            sling:resourceType="wcm/msm/components/touch-ui/renderconditions/islivecopy"
                                            ignoreIfNotCancelled="{Boolean}true"
                                            path="${empty param.item ? requestPathInfo.suffix : param.item}"/>
                                    </suspendedNote>
                                    <source
                                        granite:class="xf-lc-path"
                                        jcr:primaryType="nt:unstructured"
                                        jcr:title="Source"
                                        sling:resourceType="granite/ui/components/coral/foundation/form/fieldset">
                                        <items jcr:primaryType="nt:unstructured">
                                            <source
                                                jcr:primaryType="nt:unstructured"
                                                sling:resourceType="wcm/msm/components/coral/touch-ui/propertiesdialog/livecopy/source"
                                                path="${empty param.item ? requestPathInfo.suffix : param.item }"/>
                                        </items>
                                    </source>
                                    <status
                                        jcr:primaryType="nt:unstructured"
                                        jcr:title="Status"
                                        sling:resourceType="granite/ui/components/coral/foundation/form/fieldset">
                                        <items jcr:primaryType="nt:unstructured">
                                            <status
                                                jcr:primaryType="nt:unstructured"
                                                sling:resourceType="wcm/msm/components/touch-ui/propertiesdialog/livecopy/status"
                                                path="${empty param.item ? requestPathInfo.suffix : param.item }"/>
                                        </items>
                                    </status>
                                    <configuration
                                        jcr:primaryType="nt:unstructured"
                                        jcr:title="Configuration"
                                        sling:resourceType="granite/ui/components/coral/foundation/form/fieldset">
                                        <items jcr:primaryType="nt:unstructured">
                                            <deepinheritance
                                                granite:class="cq-siteadmin-admin-properties-livecopy-isdeep"
                                                jcr:primaryType="nt:unstructured"
                                                sling:resourceType="wcm/msm/components/touch-ui/propertiesdialog/livecopy/deepinheritance"
                                                fieldDescription="If checked Live Copy configuration is effective on all children"
                                                name="msm:isDeep"
                                                path="${empty param.item ? requestPathInfo.suffix : param.item }"
                                                text="Live Copy Inheritance"/>
                                            <inhertrolloutconfigs
                                                granite:class="cq-siteadmin-admin-properties-livecopy-inheritrolloutconfigs"
                                                jcr:primaryType="nt:unstructured"
                                                sling:resourceType="wcm/msm/components/touch-ui/propertiesdialog/livecopy/inheritrolloutconfigs"
                                                name="msm:inheritRolloutConfigs"
                                                path="${empty param.item ? requestPathInfo.suffix : param.item }"
                                                renderReadOnly="{Boolean}true"
                                                target="cq-siteadmin-admin-properties-livecopy-rolloutconfigs"
                                                text="Inherit Rollout Configs from Parent"
                                                value="true"/>
                                            <rolloutconfigs
                                                granite:class="cq-siteadmin-admin-properties-livecopy-rolloutconfigs"
                                                jcr:primaryType="nt:unstructured"
                                                sling:resourceType="wcm/msm/components/touch-ui/propertiesdialog/livecopy/rolloutconfigs"
                                                emptyText="Choose Rollout Config"
                                                name="msm:liveCopyRolloutConfigs"
                                                path="${empty param.item ? requestPathInfo.suffix : param.item }"
                                                required="true">
                                                <datasource
                                                    jcr:primaryType="nt:unstructured"
                                                    sling:resourceType="wcm/msm/components/datasources/rolloutconfig"/>
                                            </rolloutconfigs>
                                        </items>
                                        <granite:rendercondition
                                            jcr:primaryType="nt:unstructured"
                                            sling:resourceType="wcm/msm/components/touch-ui/renderconditions/islivecopy"
                                            ignoreIfCancelled="{Boolean}true"
                                            path="${empty param.item ? requestPathInfo.suffix : param.item}"/>
                                    </configuration>
                                </items>
                            </column>
                        </items>
                    </livecopy>
                </items>
            </tabs>
        </items>
    </content>
</jcr:root>
